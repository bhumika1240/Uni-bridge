extends layout

block content
  .auth-page
    .auth-card(style="max-width: 550px;") 
      .auth-header
        h1 Uni-Bridge
        p Join the community and start swapping skills

      form(action="/signup" method="POST")
        //- Name Fields (Side by Side)
        .row.mb-3
          .col-md-6
            label.form-label First Name
            input.form-control(type="text" name="firstname" placeholder="Jane" required)
          .col-md-6
            label.form-label Last Name
            input.form-control(type="text" name="lastname" placeholder="Doe" required)

        //- Date of Birth
        .mb-3
          label.form-label(for="dob") Date of Birth
          input#dob.form-control(type="date" name="dob" required)

        //- Gender Selection
        .mb-3.text-start
          label.form-label Gender
          .radio-group.d-flex.gap-3.mt-1
            label.d-flex.align-items-center.gap-1
              input(type="radio" name="gender" value="male" required)
              span Male
            label.d-flex.align-items-center.gap-1
              input(type="radio" name="gender" value="female")
              span Female
            label.d-flex.align-items-center.gap-1
              input(type="radio" name="gender" value="other")
              span Other

        //- Credentials
        .mb-3
          label.form-label Email Address
          input.form-control(type="email" name="email" placeholder="student@university.edu" required)
        
        .mb-3
          label.form-label Password
          input.form-control(type="password" name="password" placeholder="Create a strong password" required)

        //- Policy Terms Box
        .policy-box.mb-3
          h3 Terms & Conditions
          ul
            li
              strong Academic Integrity: 
              | No swapping finished assignments.
            li
              strong Student Safety: 
              | Meet only in university-verified "Safe Zones."
            li
              strong Data Minimalism: 
              | We only store essential data securely.
            li
              strong Verification: 
              | You must be a verified student.

        //- Policy Checkbox
        .form-check.text-start.mb-4
          input#policy.form-check-input(type="checkbox" name="policy" required)
          label.form-check-label.small(for="policy") I understand and agree to the Terms & Conditions

        //- Submit Button
        button.btn.btn-primary.w-100(type="submit") Create Account

      .auth-footer.mt-4
        p 
          | Already have an account? 
          a(href="/") Login