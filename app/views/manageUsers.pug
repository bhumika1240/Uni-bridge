extends layout

block content
  .dashboard-container
    //- Tells the sidebar to highlight the Admin link
    - const activePage = 'admin'
    include _sidebar

    .main-area
      header.navbar
        .nav-left
          h2 Admin Control Panel
        .nav-right
          span.admin-badge 
            i.fas.fa-user-shield 
            |  Admin: #{user.firstname}

      main.main-content
        //- Feedback Alerts
        if query && query.msg === 'UserUpdated'
          .alert.success User profile updated successfully!
        
        if query && query.msg === 'UserDeleted'
          .alert.warning User has been permanently removed.

        if query && query.msg === 'ErrorSelfDelete'
          .alert.danger Error: You cannot delete yourself.

        header.content-header
          h2 User Management
          p.text-muted There are #{allUsers ? allUsers.length : 0} students registered in Uni-Bridge.

        if allUsers && allUsers.length > 0
          .stat-card(style="overflow-x: auto; padding: 0;")
            table.table
              thead
                tr
                  th Student
                  th Contact
                  th Management & Skills
                  th Actions
              tbody
                each u in allUsers
                  tr
                    td
                      strong #{u.firstname} #{u.lastname}
                      br
                      small.text-muted Joined: #{new Date(u.created_at).toLocaleDateString()}
                    
                    td #{u.email}
                    
                    td
                      form(id=`update-form-${u.id}` action=`/admin/update/${u.id}` method="POST" class="admin-edit-form")
                        .form-group.mb-2
                          label(style="font-size: 12px; font-weight: 600;") Skills:
                          input.form-control(type="text" name="skills" value=u.skills placeholder="Java, Python...")
                        
                        .form-group.mb-2
                          label(style="font-size: 12px; font-weight: 600;") Availability:
                          input.form-control(type="text" name="availability" value=u.availability placeholder="Mon 2-4pm")

                        .form-group.mb-2
                          label(style="font-size: 12px; font-weight: 600;") Student Status:
                          select.form-control(name="status")
                            option(value="Active" selected=u.status==='Active') Active
                            option(value="Flagged" selected=u.status==='Flagged') Flagged
                            option(value="Suspended" selected=u.status==='Suspended') Suspended

                        .form-group
                          label(style="font-size: 12px; font-weight: 600;") Admin Review:
                          textarea.form-control(name="review" rows="2" placeholder="Notes about this student...") #{u.review}
                    
                    td
                      .admin-actions(style="display: flex; flex-direction: column; gap: 10px;")
                        button.btn.btn-primary.btn-sm(type="submit" form=`update-form-${u.id}`) 
                          i.fas.fa-save.me-1
                          | Save Changes
                        
                        form(action=`/admin/delete/${u.id}` method="POST" onsubmit="return confirm('Are you sure you want to delete this user? This cannot be undone.')")
                          button.btn.btn-danger.btn-sm(type="submit" style="width: 100%;") 
                            i.fas.fa-trash.me-1
                            | Delete User
        else
          .empty-state
            p No students found in the database.