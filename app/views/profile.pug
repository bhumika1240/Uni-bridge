extends layout

block content
  - const safeUser = user || {}  // fallback if user is undefined
  .container.mt-4
    .row
      // Left Column: Profile Picture & Upload
      .col-md-3.text-center
        img#profile-pic.img-thumbnail(
          src=safeUser.profilePicture || '/images/default-avatar.png',
          alt="Profile Picture"
        )
        form#upload-form(
          method="POST",
          enctype="multipart/form-data",
          action="/profile/upload"
        )
          input.form-control.form-control-sm(type="file", name="profilePicture", accept="image/*")
          button.btn.btn-primary.btn-sm.mt-2(type="submit") Upload

      // Right Column: Profile Info & Editable Form
      .col-md-9
        h1 My Profile
        form#profile-form(method="POST", action="/profile/save")
          // Skills Section
          .mb-3
            label(for="skills") Skills
            input#skills.form-control(
              type="text",
              name="skills",
              placeholder="Enter your skills",
              value=safeUser.skills || ''
            )

          // Weekly Availability Section
          .mb-3
            label Weekly Availability
            - const availability = safeUser.availability || []
            each day in ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']
              .form-check
                input.form-check-input(
                  type="checkbox",
                  name="availability",
                  value=day,
                  checked=availability.includes(day) ? true : false
                )
                label.form-check-label= day

          // Save Button
          button.btn.btn-success(type="submit") Save Profile