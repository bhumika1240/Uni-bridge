extends layout

block content
  .dashboard-container
    //- Tells the sidebar which link to highlight
    - const activePage = 'dashboard'
    include _sidebar

    .main-area
      //- Top Navbar
      header.navbar
        h2 Dashboard Overview
        .user-meta
          span Welcome, #{user.firstname}

      //- Scrollable Content Section
      main.main-content
        header.content-header
          h2 Welcome back, #{user.firstname}!
          p.text-muted Here is what's happening with your skill swaps today.
        
        //- Stats Grid
        .stats-grid
          .stat-card
            h3 Skills
            p You have #{skillCount} skills listed.
          .stat-card
            h3 Swaps
            p You have #{user.pendingSwaps} pending requests.
          
          //- Example of a third card to fill the grid
          .stat-card
            h3 Messages
            p Check your inbox for new swap proposals.