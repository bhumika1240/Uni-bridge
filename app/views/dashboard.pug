extends layout

block content
  .dashboard-container
    .navbar: h1 Uni-Bridge

    .dashboard-body
      .sidebar
        ul
          li: a.active(href="/dashboard") Dashboard
          li: a(href="/profile/view") My Profile
          li: a(href="/myswaps") My Swaps
          li: a(href="/browseskills") Browse Skills
          li: a(href="/messages") Messages
          li: a(href="/settings") Settings
          li: a(href="/logout") Logout

      .main-content
        //- Ensure this h2 is indented exactly the same as the sidebar div
        h2 Welcome to Dashboard, #{user.firstname} 👋
        
        .stats-grid
          .stat-card
            h3 Skills
            p You have #{skillCount} skills listed.
          .stat-card
            h3 Swaps
            p You have #{user.pendingSwaps} pending requests.