extends layout

block content
  .dashboard-container
    - const activePage = 'messages'
    include _sidebar

    .main-area
      header.navbar
        .nav-left
          a.btn-link.me-3(href="/messages") 
            i.fas.fa-arrow-left
          h2 Chat with #{otherUser.firstname} #{otherUser.lastname}
        .nav-right
          span.status-indicator.online Active Now

      main.main-content
        .chat-layout.stat-card(style="height: 75vh; display: flex; flex-direction: column; padding: 0;")
          //- Scrollable Message Area
          .message-list#chatBox(style="flex-grow: 1; overflow-y: auto; padding: 2rem; display: flex; flex-direction: column; gap: 1rem;")
            each msg in chatHistory
              - const isMe = (msg.sender_id == user.id)
              .message-wrapper(class=isMe ? "me" : "them")
                .bubble 
                  p(style="margin: 0;") #{msg.content}
                  span.time #{new Date(msg.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
          
          //- Input Area
          .chat-input-bar(style="padding: 1.5rem; border-top: 1px solid #eee;")
            form.d-flex.gap-2(action="/chat/send" method="POST")
              input(type="hidden" name="receiver_id" value=otherUser.id)
              input.form-control(type="text" name="content" placeholder="Write something..." required autocomplete="off")
              button.btn.btn-primary(type="submit") 
                i.fas.fa-paper-plane.me-1
                | Send