extends layout

block content
  .auth-page
    .auth-card
      .auth-header
        h1 Uni-Bridge
        p Sign in to continue to your dashboard

      if error
        .alert.alert-danger(style="color: #dc3545; background: #fee2e2; padding: 10px; border-radius: 8px; margin-bottom: 15px; font-size: 0.9rem;") 
          | #{error}

      form(action="/login" method="POST")
        .form-group
          label(for="email") Email Address
          input#email.form-control(type="email" name="email" placeholder="Enter your university email" required)
        
        .form-group.mt-3
          label(for="password") Password
          input#password.form-control(type="password" name="password" placeholder="••••••••" required)
        
        button.btn.btn-primary.w-100.mt-4(type="submit") Login

      .auth-footer.mt-4
        p 
          | Don't have an account? 
          a(href="/signup") Sign Up