extends layout

block content
  .dashboard-container
    - const activePage = 'browse'
    include _sidebar

    .main-area
      header.navbar
        h2 Browse Skills
        .user-meta Welcome, #{user.firstname}

      main.main-content
        header.content-header
          h2 Find a Mentor
          p.text-muted Search for students who have the skills you want to learn.
        
        form.search-form(action="/browseskills/search" method="POST")
          .input-group
            input.form-control(type="text" name="skill" placeholder="Search skills (e.g. Python)..." value=query || "")
            button.btn.btn-primary(type="submit") Search

        //- Your results logic stays here, but inside .main-content
        if users && users.length > 0
          .stats-grid.mt-4
            each foundUser in users
              .stat-card
                h3 #{foundUser.firstname} #{foundUser.lastname}
                p Skills: #{foundUser.all_skills}
                a.btn.btn-outline-primary(href=`/profile/user/${foundUser.id}`) View Profile